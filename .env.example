# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/cardwatch"

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (optional — enables Sign in with Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── eBay API ──────────────────────────────────────────────────────────────────
# Required for eBay listing searches (Browse API) and sold-price lookups (Finding API)
# Create an app at https://developer.ebay.com/my/keys
EBAY_APP_ID=""      # Client ID / App ID
EBAY_CERT_ID=""     # Client Secret / Cert ID

# ── SportsCardsPro ────────────────────────────────────────────────────────────
# Required for market price data. Without this, market averages are disabled.
SCP_API_KEY=""

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Email ─────────────────────────────────────────────────────────────────────
# Option 1: Resend (preferred)
RESEND_API_KEY=""

# Option 2: SMTP fallback
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ── Push Notifications (Web Push / VAPID) ────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# ── Rate Limiting (Upstash Redis) ─────────────────────────────────────────────
# Optional — if not set, rate limiting is disabled
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Used to manually trigger cron endpoints: Authorization: Bearer $CRON_SECRET
CRON_SECRET=""

# ── Admin ─────────────────────────────────────────────────────────────────────
# Used to generate invite codes via /api/invites/generate
ADMIN_SECRET=""
